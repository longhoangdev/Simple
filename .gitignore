*.scc

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Docker
.env

# IMPORTANT: Sensitive configuration files
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json
appsettings.Local.json
appsettings.*.json
!appsettings.json
!appsettings.*.example.json

# Connection strings and secrets
**/connectionstrings.json
**/secrets.json
*.pfx
*.p12

# Database
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Redis dump
dump.rdb

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files
*.bak
*.backup
*~

# Publish profiles
PublishProfiles/
*.pubxml
*.publishproj

# Temporary files
*.swp
*.swo
*~

# JetBrains Rider auto-generated files
_ReSharper*/
*.[Rr]e[Ss]harper

# Test Results
*/**/TestResults/*
*/**/coveragereport/*
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
